{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@adapters": [
        "src/adapters"
      ],
      "@adapters/*": [
        "src/adapters/*"
      ],
      "@contexts": [
        "src/contexts"
      ],
      "@contexts/*": [
        "src/contexts/*"
      ],
      "@libs": [
        "src/libs"
      ],
      "@libs/*": [
        "src/libs/*"
      ]
    }
  }
}